# Port the API server listens on
PORT=5000

# MongoDB connection details
MONGODB_URI=
MONGODB_DB=

# Secret key for signing session JWT cookies
JWT_SECRET=

# Allowed CORS client URL (e.g. https://my-food-menu.vercel.app)
# Required in production to allow cookies to be shared across origins
FRONTEND_URL=

# Razorpay payments gateway public/secret key credentials
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary image hosting credentials (for menu item photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth Client ID (for staff authentication verifyIdToken)
GOOGLE_CLIENT_ID=
